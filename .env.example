# Catholic Network Tools — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ─── AI ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── DATABASE ──────────────────────────────────
CNT_DB_PATH=data/parishes.db

# ─── M-PESA (Safaricom Daraja) ─────────────────
# Get credentials at: developer.safaricom.co.ke
MPESA_ENV=sandbox                          # "sandbox" | "live"
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379                     # Daraja sandbox default
MPESA_PASSKEY=your_passkey_from_daraja
MPESA_CALLBACK_URL=https://your-webhook.onrender.com/mpesa/callback

# ─── WHATSAPP BOT ──────────────────────────────
# Choose one provider:
WHATSAPP_PROVIDER=africas_talking          # "africas_talking" | "twilio"

# Africa's Talking: account.africastalking.com
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_at_api_key

# Twilio (alternative): console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # Sandbox number

# ─── GCATHOLIC (RAILS — NOT ACTIVE) ────────────
# Only set to true after completing docs/GCATHOLIC_INTEGRATION_GUIDE.md
GCATHOLIC_ENABLED=false
