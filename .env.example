# Jumuia — Parish Community · Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# On Streamlit Cloud: add these under Settings → Secrets (TOML format).

# ─── AI (Gemini) ───────────────────────────────
# Get at: aistudio.google.com → Get API Key
GOOGLE_API_KEY=AIza...your_gemini_key_here

# ─── GOOGLE SHEETS PERSISTENCE ─────────────────
# Deploy docs/AppsScript_Sheets.js to Google Apps Script → get the web app URL
# Required for parish submissions, sacrament records, SCC records to persist
SHEETS_ENDPOINT=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ─── M-PESA (Safaricom Daraja) ─────────────────
# Get at: developer.safaricom.co.ke → Create App
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-webhook.run.app/mpesa/callback

# ─── USSD + SMS — Africa's Talking ────────────
# Get at: account.africastalking.com → Settings → API Key
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=atsk_...your_key_here
# Your registered USSD shortcode (e.g. *384*12345#)
USSD_SERVICE_CODE=*384*...

# ─── WhatsApp ──────────────────────────────────
WHATSAPP_PROVIDER=africas_talking
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── OPTIONAL: Anthropic (not default) ─────────
# Only needed if you switch ai_service.py to use Claude instead of Gemini
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── DEPRECATED ────────────────────────────────
# CNT_DB_PATH=data/parishes.db  # Not used — Google Sheets is the store
# GCATHOLIC_ENABLED=false        # Not active
