# Catholic Network Tools — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ─── AI ────────────────────────────────────────
# Get at: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-...your_key_here

# ─── DATABASE ──────────────────────────────────
CNT_DB_PATH=data/parishes.db

# ─── M-PESA (Safaricom Daraja) ─────────────────
# Get credentials at: developer.safaricom.co.ke → Create App
MPESA_ENV=sandbox                          # "sandbox" | "live"
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379                     # Daraja sandbox default
MPESA_PASSKEY=your_passkey_from_daraja     # Daraja app → Lipa na M-Pesa Online
MPESA_CALLBACK_URL=https://your-webhook.onrender.com/mpesa/callback

# ─── WHATSAPP + USSD — Africa's Talking ────────
# Get at: account.africastalking.com → Settings → API Key
WHATSAPP_PROVIDER=africas_talking          # "africas_talking" | "twilio"
AFRICASTALKING_USERNAME=sandbox            # "sandbox" for testing, your AT username for live
AFRICASTALKING_API_KEY=atsk_...your_key_here

# Twilio (alternative): console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── GCATHOLIC (RAILS — NOT ACTIVE) ────────────
# Only set to true after completing docs/GCATHOLIC_INTEGRATION_GUIDE.md
GCATHOLIC_ENABLED=false
